VITE_APP_NAME=Auth Starter
VITE_API_URL=http://localhost:3000/api

# Puede ser ruta local (/login) o URL absoluta de otra app (https://app.tudominio.com/dashboard)
VITE_AUTH_LOGIN_REDIRECT=http://localhost:5174/dashboard

# Puede ser ruta local o URL absoluta del sistema público externo
VITE_AUTH_LOGOUT_REDIRECT=http://localhost:5174/

# Fallback público de esta UI auth (local o externo)
VITE_DEFAULT_PUBLIC_ROUTE=/login
