# App
APP_NAME=Auth Starter
APP_URL=http://localhost:5173
API_URL=http://localhost:3000/api
PORT=3000
NODE_ENV=development
TRUST_PROXY=false

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/auth_db

# Security / JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Cookies
COOKIE_NAME_ACCESS=access_token
COOKIE_NAME_REFRESH=refresh_token
COOKIE_DOMAIN=

# Auth redirects
LOGIN_SUCCESS_REDIRECT=/dashboard
LOGOUT_REDIRECT=/login
DEFAULT_AUTH_REDIRECT=/dashboard

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Metrics
METRICS_ENABLED=false
METRICS_USERNAME=admin
METRICS_PASSWORD=strong_password_for_metrics

# Email
RESEND_API_KEY=
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Auth Starter Kit" <noreply@example.com>
